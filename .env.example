# App configuration
AGENT_PLANNER=rule
AGENT_DB_PATH=sqlite+pysqlite:///procurement.sqlite3

# Logging
# LOG_LEVEL controls verbosity (DEBUG, INFO, WARNING, ERROR). Default INFO.
LOG_LEVEL=INFO
LLM_LOG_IO=0

# Live LLM planner configuration
# Set AGENT_PLANNER=llm to use this path.
LLM_MODEL=gemini/gemini-3.1-flash-lite
LLM_TIMEOUT_SECONDS=20
LLM_MAX_RETRIES=1
LLM_TEMPERATURE=0

# Provider credentials
# Use the variable expected by your model provider.
# Examples:
# GEMINI_API_KEY=replace-with-your-key
# OPENAI_API_KEY=replace-with-your-key
